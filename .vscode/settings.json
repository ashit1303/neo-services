{
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#2b5841",
    "activityBar.background": "#2b5841",
    "activityBar.foreground": "#e7e7e7",
    "activityBar.inactiveForeground": "#e7e7e799",
    "activityBarBadge.background": "#20152b",
    "activityBarBadge.foreground": "#e7e7e7",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#2b5841",
    "statusBar.background": "#1a3628",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#2b5841",
    "statusBarItem.remoteBackground": "#1a3628",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#1a3628",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#1a362899",
    "titleBar.inactiveForeground": "#e7e7e799"
  },
  "editor.tabSize": 2,
  "editor.wordWrap": "on",
  "editor.insertSpaces": true,
  "editor.defaultFormatter": "dbaeumer.vscode-eslint",
  "editor.formatOnSave": true,
  "editor.quickSuggestions": {
    "strings": true
  },
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "[jsonc]": {
    "editor.defaultFormatter": "vscode.json-language-features"
  },
  "[typescript]": {
    "editor.defaultFormatter": "vscode.typescript-language-features"
  },
  // "[typescript]": {
  //   "editor.defaultFormatter": "vscode.typescript-language-features"
  // },
}