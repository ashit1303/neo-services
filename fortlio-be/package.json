{
  "name": "fortlio",
  "version": "1.0.0",
  "main": "server.ts",
  "type": "module",
  "scripts": {
    "local": "BUN_ENV=local bun --watch --inspect run server.ts",
    "local-prod": "BUN_ENV=local bun run server.ts",
    "prod": "BUN_ENV=prod bun server.ts",
    "dev": "BUN_ENV=dev bun server.ts",
    "watch": "BUN_ENV=local bun --watch server.ts",
    "build-dev": "bun build server.ts --outdir dist --target=bun --sourcemap",
    "build": "bun build server.ts --outdir dist --target=bun --minify --sourcemap && cp -r src/ejs-templates dist/templates",
    "start-prod": "pm2 start bun --name \"bun-script\" -- run local-prod",
    "bake": "bun build --compile --minify --bytecode --define \"process.env.BUN_ENV='local'\" ./server.ts --outfile server-local",
    "start": "BUN_ENV=prod bun dist/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": " BUN_ENV=local jest --detectOpenHandles --forceExit"
  },
  "license": "ISC",
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aws-sdk/client-s3": "^3.823.0",
    "@aws-sdk/client-secrets-manager": "^3.777.0",
    "@aws-sdk/client-sesv2": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.832.0",
    "@clickhouse/client": "^1.15.0",
    "@toon-format/toon": "^2.3.0",
    "bullmq": "^5.76.8",
    "connect-redis": "^9.0.0",
    "cors": "^2.8.5",
    "csv-parse": "^6.1.0",
    "dayjs": "^1.11.20",
    "ejs": "3.1.9",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "mongodb": "^6.13.1",
    "mongoose": "^8.14.0",
    "nodemailer": "^8.0.7",
    "playwright": "^1.60.0",
    "swagger-ui-express": "^5.0.1",
    "typesense": "^3.0.6",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/cors": "^2.8.19",
    "@types/ejs": "^3.1.5",
    "@types/express": "4.17.21",
    "@types/express-serve-static-core": "^4.19.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.6.0",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.28.0",
    "@typescript-eslint/parser": "^8.28.0",
    "eslint": "^9.23.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.1"
  },
  "engines": {
    "bun": ">=1.0.0"
  }
}