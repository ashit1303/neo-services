  <!DOCTYPE html>
  <html lang="en">
  <head>
  <meta charset="UTF-8" />
  <title>OTP Verification</title>

  <style>
/* ===== PAGE SETUP ===== */
/* @page removed because email clients ignore it */
body {
  margin: 0;
  font-family: Arial, sans-serif;
  background: #1a1a1a;
  color: #111;
}
.page {
  width: 210mm;
  margin: auto;
  background: #fff9f9;
  padding: 20mm;
  box-sizing: border-box;
  position: relative;
}

/* ===== HEADER ===== */
.header {
  text-align: center;
  background: #000; /* was var(--bg-header) */
  padding: 12px 0;
  border-bottom: 4px solid #e53935; /* was var(--accent-red) */
}
.header img {
  max-height: 60px;
}

/* ===== MAIN TITLE ===== */
h1 {
  text-align: center;
  font-size: 32px;
  margin: 18px 0;
  color: #111; /* was var(--text-light) */
}

/* ===== SECTION TITLES ===== */
.section-title {
  font-size: 18px;
  color: #e53935; /* was var(--accent-red) */
  font-weight: bold;
  margin-top: 20px;
  margin-bottom: 8px;
  border-bottom: 2px solid #e53935; /* was var(--accent-red) */
  display: block;
  text-align: center;
  padding-bottom: 3px;
}

/* ===== DETAILS GRID ===== */
/* grid removed for email; fallback to block with spacing */
.details-grid > div {
  margin-bottom: 8px;
  font-size: 14px;
}
.details-grid .label {
  font-weight: bold;
  color: #e53935; /* was var(--accent-red) */
}

/* ===== TABLE ===== */
table {
  width: 100%;
  border-collapse: collapse;
  margin-top: 12px;
  font-size: 14px;
}
th, td {
  border: 1px solid #e53935; /* was var(--accent-red) */
  padding: 8px;
  text-align: center;
}
th {
  background: #e53935; /* was var(--accent-red) */
  color: #111; /* was var(--text-light) */
}

/* ===== NOTES ===== */
.notes {
  margin-top: 14px;
  font-size: 12px;
  color: #111; /* was var(--text-light) */
}

/* ===== FOOTER ===== */
.footer {
  text-align: center;
  font-size: 12px;
  border-top: 2px solid #e53935; /* was var(--accent-red) */
  padding-top: 10px;
  margin-top: 20px;
  color: #111; /* was var(--text-light) */
}
</style>
  </head>

  <body>
  <div class="page">

    <!-- HEADER -->
    <div class="header">
      <!-- Using your logo file directly from the Oben storage -->
      <img src="https://oben-website-content.s3.ap-south-1.amazonaws.com/email-template-images/Obenlogo.png" alt="Oben Electric Logo" />
    </div>

    <!-- MAIN TITLE -->
    <h1>OTP Verification: COMPANY</h1>

    <!-- CUSTOMER DETAILS -->
    <div class="section-title">OTP Details</div>
    <div class="details-grid">
      <div><span class="label">Email:</span> <%= email %></div>
      <div><span class="label">OTP:</span> <%= otp %></div>
    </div>


    <!-- NOTES -->
    <div class="notes">
      Prices and offers prevailing on the date of registration shall be applicable.<br><br>
      (This is a computer-generated receipt and does not require a physical signature.)
    </div>

    <!-- FOOTER -->
    <div class="footer">
      <p>&copy; 2023 Company. All rights reserved.</p>
    </div>

  </div>
  </body>
  </html>